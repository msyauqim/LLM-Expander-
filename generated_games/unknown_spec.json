  "game_content": {
    "instructions": "Susun kata-kata berikut untuk membentuk rumus GLBB yang benar. Pilih huruf dari grid dan susun di area jawaban.",
    "vocabulary_items": [
      {
        "term": "percepatan",
        "definition": "Perubahan kecepatan per satuan waktu",
        "formula": "a = (vt - v0) / t"
      },
      {
        "term": "kecepatan akhir",
        "definition": "Kecepatan benda setelah mengalami percepatan",
        "formula": "vt = v0 + a.t"
      },
      {
        "term": "jarak tempuh",
        "definition": "Panjang lintasan yang ditempuh benda",
        "formula": "s = v0.t + ½.a.t²"
      }
    ],
